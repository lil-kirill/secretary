BOT_TOKEN=your_telegram_bot_token
LLM_API_KEY=your_openrouter_api_key
LLM_API_URL=https://openrouter.ai/api/v1/chat/completions
LLM_MODEL=openai/chatgpt-4o-latest

# Fireflies.ai (optional — conference transcription)
FIREFLIES_API_KEY=

# Admin (Telegram user ID who can approve/reject users)
ADMIN_USER_ID=0

# Access control: true = new users need admin approval, false = open for everyone
APPROVAL_REQUIRED=true

# Web dashboard
WEB_SECRET_KEY=change-me-random-string
BOT_USERNAME=YourBotUsername
